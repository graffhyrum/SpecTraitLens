package-as: SpecTraitLens
enable-nolib-creation: no

ignore:
  - .git
  - .github
  - Tests
  - libs
  - justfile
  - .busted
  - .luacheckrc
  - .beads
  - .cursor
  - .codex
  - .claude
  - .specstory
  - .vscode
  - .agents
  - .changeset
  - docs
  - scripts
  - CONTEXT.md
  - AGENTS.md
  - CLAUDE.md
  - package.json
  - package-lock.json
  - bun.lock
  - "*.md"
  - "!libs/README.md"
  - "!libs/THIRD_PARTY_NOTICES.md"
  - assets/logo/logo-master.png
